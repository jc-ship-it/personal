# 站点 URL（用于 sitemap、robots，可选）
NEXT_PUBLIC_SITE_URL=https://zhangjiachang.com

# Sanity CMS（复制为 .env.local 并填入真实值，勿提交）
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_ORG_ID=your_org_id

# 开发者模式密码（服务端验证，无需 NEXT_PUBLIC_ 前缀）
DEV_MODE_PASSWORD=800820

# Optional: protect on-demand revalidation API
SANITY_REVALIDATE_SECRET=your_secret
